// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// Data Model: após a definição do modelo executar `npx prisma generate -name banana` para gerar o client do prisma

// Tabela de Roles
model roles {
  id_role Int @id @default(autoincrement())
  nome_role String
  // Relacionamentos N para N
  usuarios UsuarioRoles[]
}
// Usuarios
model usuarios {
  id_usuario Int @id @default(autoincrement())
  nome_usuario String
  email_usuario String @unique
  senha_usuario String
  // Relacionamentos 1 para N
  contatos contatos[]
  // Relacionamentos N para N
  roles UsuarioRoles[]
}

// Tabela de associação para o relacionamento N para N entre usuários e roles
model UsuarioRoles {
  id_usuario Int
  id_role Int
  usuario usuarios @relation(fields: [id_usuario], references: [id_usuario])
  role roles @relation(fields: [id_role], references: [id_role])
  @@id([id_usuario, id_role]) // Chave primária composta
}
// Contatos da Agenda
model contatos {
  id_contato Int @id @default(autoincrement())
  nome_contato String
  email_contato String
  telefone_contato String
  // Relacionamentos N para 1
  usuario usuarios @relation(fields: [id_usuario], references: [id_usuario])
  id_usuario Int
}