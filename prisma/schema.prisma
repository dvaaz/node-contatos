// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// Roles do Usuario Admin ou User
model Roles { // Define as responsabilidades
  id    String @id @default(uuid())
  name  String @unique
  createdAt DateTime @default(now())
  users Users[]
  userRoles UserRoles[]

  @@map("roles") // Define como será a referência ao objeto 
}

// Todos usuarios do sistema, admin e users
model Users { // Usuarios do sistema
  id    String     @id @default(uuid())
  name  String
  email String  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  roles Roles @relation(fields: [roleId], references: [id])
  roleId String
  contacts Contacts[]
  userRoles UserRoles[]
  
  @@map("users") // Define como será a referência ao objeto 
}

// Contatos do sistema, não há tabela de ligacao, logo podem haver contatos repetidos, razõ a qual o email não é unico
model Contacts { // Contatos do sistema
  id String @id @default(uuid())
  name String
  email String
  phone String
  userId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user Users @relation(fields: [userId], references: [id])

  @@map("contacts") // Define como será a referência ao objeto
}

// Tabela de relacionamento entre usuários e suas responsabilidades, um usuário pode ter várias responsabilidades e uma responsabilidade pode ser atribuída a vários usuários
model UserRoles { // Tabela de relacionamento entre usuários e suas responsabilidades
  id String @id @default(uuid())
  userId String
  roleId String

  user Users @relation(fields: [userId], references: [id])
  role Roles @relation(fields: [roleId], references: [id])

  @@map("user_roles") // Define como será a referência ao objeto
}